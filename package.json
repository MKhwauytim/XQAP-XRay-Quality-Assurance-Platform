{
  "name": "x-ray-quality-app",
  "private": true,
  "version": "57.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:ci": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "check:hex-literals": "node scripts/check-hex-literals.mjs",
    "check:complexity": "eslint src --max-warnings 0 --rule \"complexity: [error, 60]\" --rule \"max-lines-per-function: [error, 1450]\"",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:release": "node scripts/check-release-consistency.mjs",
    "check:release-consistency": "node scripts/check-release-consistency.mjs",
    "check:vendor": "node scripts/check-vendor-integrity.mjs",
    "count-lines": "node scripts/count-lines.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans-arabic": "^5.2.9",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "file:vendor/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.8"
  }
}
